<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DiaCare" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary color (action bar, etc.) -->
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorPrimaryVariant">@color/primary_teal_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Secondary color (FABs, switches, etc.) -->
        <item name="colorSecondary">@color/soft_pink</item>
        <item name="colorSecondaryVariant">@color/soft_pink_dark</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_warm</item>
        <item name="colorSurface">@color/card_white</item>

        <!-- Error -->
        <item name="colorError">@color/status_danger</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_teal_dark</item>

        <!-- Action bar style -->
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
    </style>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white"
    android:padding="24dp"
    tools:context=".MainActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDailyTip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/card_white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Daily Tip"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewDailyTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/daily_tip_loading"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonBloodSugar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/blood_sugar_tracking"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/button_green"
        app:layout_constraintTop_toBottomOf="@id/cardDailyTip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCarbCalc"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/carb_calculator"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/button_red"
        app:layout_constraintTop_toBottomOf="@id/buttonBloodSugar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
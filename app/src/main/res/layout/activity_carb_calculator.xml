<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_warm"
    android:padding="24dp"
    tools:context=".CarbCalculatorActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Total Carbs Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTotalCarbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Carbs"
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/textTotalCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 g"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_teal" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Select Food Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSelectFood"
                style="@style/DiaCare.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/select_food"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                app:icon="@drawable/ic_apple"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <!-- Selected Food Display -->
            <TextView
                android:id="@+id/textSelectedFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_food_selected"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Selected Foods List Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFoodList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/selected_foods_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_teal"
                        android:layout_marginBottom="12dp" />

                    <ScrollView
                        android:id="@+id/scrollViewFoods"
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <LinearLayout
                            android:id="@+id/layoutFoodList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </ScrollView>

                    <TextView
                        android:id="@+id/textNoFoods"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_foods_added"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:padding="24dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddFood"
                style="@style/DiaCare.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/add_selected_food"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClear"
                style="@style/DiaCare.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/clear"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
